#!/usr/bin/env fish

#
# createzap.fish
#
# Generate a Homebrew Cask zap stanza from common macOS
# preference/support locations.
#
# Usage:
#   ./createzap.fish "Raycast"
#   ./createzap.fish "Visual Studio Code"
#

set -g SEARCH_PATHS \
    "$HOME/Desktop" \
    "$HOME/Documents" \
    "$HOME/Library" \
    "$HOME/Library/Application Scripts" \
    "$HOME/Library/Application Support" \
    "$HOME/Library/Application Support/com.apple.sharedfilelist/com.apple.LSSharedFileList.ApplicationRecentDocuments" \
    "$HOME/Library/Caches" \
    "$HOME/Library/Caches/com.apple.helpd/Generated" \
    "$HOME/Library/Caches/com.apple.helpd/SDMHelpData/Other/English/HelpSDMIndexFile" \
    "$HOME/Library/Containers" \
    "$HOME/Library/Cookies" \
    "$HOME/Library/Group Containers" \
    "$HOME/Library/HTTPStorages" \
    "$HOME/Library/Internet Plug-Ins" \
    "$HOME/Library/LaunchAgents" \
    "$HOME/Library/Logs" \
    "$HOME/Library/PreferencePanes" \
    "$HOME/Library/Preferences" \
    "$HOME/Library/Saved Application State" \
    "$HOME/Library/WebKit" \
    "$HOME/Music" \
    "/Library/Application Support" \
    /Library/Caches \
    /Library/LaunchDaemons \
    /Library/PreferencePanes \
    /Library/Preferences \
    /Library/PrivilegedHelperTools \
    "/Library/Screen Savers" \
    /Library/ScriptingAdditions \
    /Library/Services \
    /Users/Shared \
    "/etc/newsyslog.d"

function usage
    echo "Usage: "(status filename)" <application-name>"
    echo
    echo "Examples:"
    echo "  "(status filename)" Raycast"
    echo "  "(status filename)' "Visual Studio Code"'
    exit 1
end

#
# Try to discover a bundle identifier from a matching .app.
# Only checks common application locations to keep behavior
# simple, fast and predictable.
#
function get_bundle_id --argument app_name

    set -l candidates \
        "/Applications/$app_name.app" \
        "$HOME/Applications/$app_name.app"

    for app in $candidates
        if test -d "$app"

            set -l bundle_id \
                (defaults read "$app/Contents/Info" CFBundleIdentifier 2>/dev/null)

            if test -n "$bundle_id"
                echo "$bundle_id"
                return 0
            end
        end
    end

    return 1
end

#
# Return success if path matches any search term.
#
function path_matches --argument path

    for term in $SEARCH_TERMS
        if string match -iq "*$term*" "$path"
            return 0
        end
    end

    return 1
end

#
# Search configured directories (non-recursive).
#
function search_locations

    set -l matches

    for dir in $SEARCH_PATHS

        if not test -d "$dir"
            continue
        end

        for path in "$dir"/*

            # Fish leaves unmatched globs untouched.
            if not test -e "$path"
                continue
            end

            if path_matches "$path"
                set matches $matches "$path"
            end
        end
    end

    printf "%s\n" $matches
end

#
# Search only first level of home directory.
#
function search_home

    find "$HOME" -maxdepth 1 2>/dev/null | while read -l path

        if path_matches "$path"
            echo "$path"
        end
    end
end

function generate_output

    set -l results

    set results $results (search_locations)
    set results $results (search_home)

    if test (count $results) -eq 0
        echo "No matching settings found."
        echo "# No zap stanza required"
        return 0
    end

    set results \
        (printf "%s\n" $results | sort -fu)

    set -l count (count $results)

    if test $count -eq 1

        set -l item \
            (string replace "$HOME" "~" "$results[1]")

        echo "zap trash: \"$item\""
        return 0
    end

    echo "zap trash: ["

    for item in $results

        set item \
            (string replace "$HOME" "~" "$item")

        echo "  \"$item\","
    end

    echo "]"
end

#
# Main
#
if test (count $argv) -ne 1
    usage
end

set -g SEARCH_TERMS "$argv[1]"

set -l bundle_id (get_bundle_id "$argv[1]")

if test -n "$bundle_id"
    set -a SEARCH_TERMS "$bundle_id"
end

generate_output
